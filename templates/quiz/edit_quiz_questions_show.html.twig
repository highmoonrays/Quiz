{% extends 'base.html.twig' %}

{% block title %}Question index{% endblock %}

{% block body %}
    {{ parent() }}

    <h1>Question index</h1>

    <table class="table">
        <thead>
        <tr>
            <th>Id</th>
            <th>Name</th>
            <th>Question_text</th>
            <th>actions</th>
        </tr>
        </thead>
        <tbody>
        {% for question in questions %}
            <tr>
                <td>{{ question.id }}</td>
                <td>{{ question.name }}</td>
                <td>{{ question.questionText }}</td>
                <td>
                    <a href="{{ path('question_show', {'id': question.id}) }}">show</a>
                    <a href="{{ path('question_edit', {'id': question.id}) }}">edit</a>
                    <a href="{{ path('edit_quiz_question_add', {'quiz_id': quiz.id, 'id': question.id}) }}">add</a>
                </td>
            </tr>
        {% else %}
            <tr>
                <td colspan="4">no records found</td>
            </tr>
        {% endfor %}
        </tbody>
    </table>

    <a href="{{ path('edit_quiz_question_create', {'id': quiz.id}) }}">Create new</a>
{% endblock %}